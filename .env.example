# LiveKit Configuration (Optional - only needed for LiveKit Cloud deployment)
# Get these from https://cloud.livekit.io or your self-hosted instance
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# OpenAI Configuration (Required)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Deepgram Configuration (Required)
# Get from https://console.deepgram.com
DEEPGRAM_API_KEY=your-deepgram-api-key

# Model Selection (Optional)
# Choose which OpenAI model to use
LLM_CHOICE=gpt-4.1-mini

# Cognee memory — cloud (recommended) or local graph recall on stable STT transcripts
# Cloud: set COGNEE_BASE_URL (or COGNEE_SERVICE_URL) and COGNEE_API_KEY
COGNEE_BASE_URL=https://your-tenant.aws.cognee.ai
COGNEE_API_KEY=your-cognee-api-key
SESSIONS_DATASET=default_dataset
COGNEE_RECALL_TYPE=CHUNKS
COGNEE_RECALL_TIMEOUT=8.0
# Optional: auto-ingest on startup when cloud graph is empty (comma-separated paths)
# COGNEE_BOOTSTRAP_PATH=../nyra-livekit/notes/user_context.md

# Local Cognee fallback (used when cloud vars are not set)
COGNEE_SYSTEM_ROOT_DIRECTORY=.cognee_system
LLM_MODEL=gpt-4o-mini

# Development Settings (Optional)
LOG_LEVEL=INFO
DEBUG_MODE=false
