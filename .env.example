# LiveKit Configuration (Optional - only needed for LiveKit Cloud deployment)
# Get these from https://cloud.livekit.io or your self-hosted instance
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# OpenAI Configuration (Required)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Deepgram Configuration (Required)
# Get from https://console.deepgram.com
DEEPGRAM_API_KEY=your-deepgram-api-key

# Model Selection (Optional)
# Choose which OpenAI model to use
LLM_CHOICE=gpt-4.1-mini

# Cognee memory — cloud (recommended) or local graph recall on stable STT transcripts
# Cloud: set COGNEE_BASE_URL (or COGNEE_SERVICE_URL) and COGNEE_API_KEY
COGNEE_BASE_URL=https://your-tenant.aws.cognee.ai
COGNEE_API_KEY=your-cognee-api-key
SESSIONS_DATASET=default_dataset
COGNEE_RECALL_TYPE=CHUNKS
COGNEE_RECALL_TIMEOUT=8.0
# Optional: auto-ingest on startup when cloud graph is empty (comma-separated paths)
# COGNEE_BOOTSTRAP_PATH=../nyra-livekit/notes/user_context.md

# Local Cognee fallback (used when cloud vars are not set)
COGNEE_SYSTEM_ROOT_DIRECTORY=.cognee_system
LLM_MODEL=gpt-4o-mini

# Development Settings (Optional)
LOG_LEVEL=INFO
DEBUG_MODE=false

# Nyra waiting speech (Optional) — filler phrases during long thinking / tool calls
NYRA_FILLER_DELAY_SECONDS=2.5
NYRA_FILLER_MIN_INTERVAL=8.0
# Ignore single-word STT fragments while the agent is speaking (prevents false interrupts)
NYRA_MIN_INTERRUPTION_WORDS=2

# Wake word / passive listening (Optional) — openWakeWord gates the voice pipeline
# When enabled, Nyra starts in standby and activates on the wake word "Alexa".
# Swap NYRA_WAKEWORD_MODEL_PATH/NYRA_WAKEWORD_PLACEHOLDER_MODEL for a custom model later.
NYRA_WAKEWORD_ENABLED=true
NYRA_WAKEWORD_MODEL_PATH=models/alexa_v0.1.onnx
NYRA_WAKEWORD_MODELS_DIR=models
NYRA_WAKEWORD_PLACEHOLDER_MODEL=alexa
NYRA_WAKEWORD_THRESHOLD=0.5
NYRA_WAKEWORD_DEBOUNCE_SECONDS=2.0
NYRA_WAKEWORD_ACK_ON_ACTIVATE=false

# Hermes background agent (Optional) — async delegation via hermes gateway API
# Requires: API_SERVER_ENABLED=true and hermes gateway running on same host
# Gateway startup warnings about allowlists / "no messaging platforms" are normal
# for API-only Nyra use — leave gateway running; verify with: curl localhost:8642/health
HERMES_API_URL=http://127.0.0.1:8642
HERMES_API_KEY=your-hermes-api-server-key
HERMES_SESSION_KEY=nyra
HERMES_MAX_CONCURRENT=3
HERMES_POLL_INTERVAL=2.0
HERMES_RESULT_MAX_CHARS=1200

# Nyra status window (Optional) — pygame visualization, runs as its own process
NYRA_UI_ENABLED=true
NYRA_UI_HOST=127.0.0.1
NYRA_UI_PORT=8790
NYRA_UI_RECONNECT_MAX_BACKOFF=10.0
