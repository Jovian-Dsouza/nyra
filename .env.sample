# Copy to .env and fill in values. Shell environment variables take precedence.

# --- TTS ---
# local = Piper (default), sarvam = Sarvam Bulbul v3 API
NYRA_TTS_BACKEND=local

# Required when NYRA_TTS_BACKEND=sarvam
SARVAM_API_KEY=

# Sarvam voice options (when using sarvam backend)
NYRA_SARVAM_TTS_LANGUAGE=en-IN
NYRA_SARVAM_TTS_SPEAKER=ritu

# Piper (when using local backend)
# NYRA_PIPER_COMMAND=piper
# NYRA_PIPER_VOICE=models/tts/voice.onnx
# NYRA_TTS_PLAY_COMMAND=aplay -q

# --- Hermes agent ---
# NYRA_HERMES_COMMAND=
# NYRA_HERMES_SESSION_IDLE_TIMEOUT_S=180

# --- Wakeword ---
# NYRA_WAKEWORD_MODEL=models/wakeword/hey_nyra.onnx
# NYRA_WAKEWORD_BACKEND=arecord
# NYRA_WAKEWORD_MODEL_KEY=
# NYRA_WAKEWORD_THRESHOLD=0.5
# NYRA_WAKEWORD_SAMPLE_RATE=16000
# NYRA_WAKEWORD_FRAME_SAMPLES=1280
# NYRA_WAKEWORD_COOLDOWN_S=1.2
# NYRA_WAKEWORD_INPUT_DEVICE=
# NYRA_WAKEWORD_ARECORD_DEVICE=

# --- Speech-to-text ---
# NYRA_STT_MODEL=models/stt/vosk-model-small-en-us-0.15
# NYRA_STT_MODEL_URL=https://alphacephei.com/vosk/models/vosk-model-small-en-us-0.15.zip
# NYRA_STT_SAMPLE_RATE=16000
# NYRA_STT_CHUNK_BYTES=4000
# NYRA_STT_ARECORD_DEVICE=

# --- Runtime ---
# NYRA_REQUIRE_AUDIO=true
# NYRA_LOG_LEVEL=INFO
# NYRA_DEV_CONSOLE=false
